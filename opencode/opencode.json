{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "/Users/victor/dev/vmvarela/opencode-quota",
    "@dietrichgebert/ponytail",
    "caveman-opencode-plugin",
    "oh-my-opencode-slim",
    "openslimedit@latest"
  ],
  "default_agent": "plan",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "plan": {
      "model": "opencode/nemotron-3-ultra-free"
    },
    "build": {
      "model": "opencode/deepseek-v4-flash-free"
    }
  },
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": ["copilot", "opencode-go", "openai"],
      "formatStyle": "grouped",
      "percentDisplayMode": "used"
    }
  },
  "lsp": true,
  "disabled_providers": ["openrouter"],
  "mcp": {
    "engram": {
      "type": "local",
      "command": ["/opt/homebrew/bin/engram", "mcp", "--tools=agent"],
      "enabled": true
    }
  }
}
