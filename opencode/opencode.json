{
    "$schema": "https://opencode.ai/config.json",
    "plugin": ["oh-my-opencode-slim", "@slkiser/opencode-quota"],
    "default_agent": "plan",
    "agent": {
        "explore": {
            "disable": true
        },
        "general": {
            "disable": true
        },
        "plan": {
            "model": "opencode/nemotron-3-ultra-free"
        },
        "build": {
            "model": "opencode/deepseek-v4-flash-free"
        }
    },
    "experimental": {
        "quotaToast": {
            "enableToast": false,
            "showSessionTokens": true,
            "enabledProviders": ["copilot", "opencode-go", "openai", "nvidia"],
            "formatStyle": "grouped",
            "percentDisplayMode": "used"
        }
    }
}
