{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "/Users/victor/dev/vmvarela/opencode-quota",
    "@dietrichgebert/ponytail",
    "caveman-opencode-plugin",
    "oh-my-opencode-slim",
    "@tarquinen/opencode-dcp@latest",
    "openslimedit@latest"
  ],
  "default_agent": "plan",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "plan": {
      "model": "opencode/nemotron-3-ultra-free",
      // "disable": true
    },
    "build": {
      "model": "opencode/deepseek-v4-flash-free",
      // "disable": true
    }
  },
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": [
        "copilot",
        "opencode-go",
        "openai"
      ],
      "formatStyle": "grouped",
      "percentDisplayMode": "used"
    }
  },
  "lsp": true
}
