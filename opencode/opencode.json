{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@slkiser/opencode-quota",
    "oh-my-opencode-slim"
  ],
  "default_agent": "plan",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "plan": {
      "model": "opencode/nemotron-3-ultra-free",
      "disable": true
    },
    "build": {
      "model": "opencode/deepseek-v4-flash-free",
      "disable": true
    }
  },
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": [
        "copilot",
        "opencode-go",
        "openai",
        "nvidia"
      ],
      "formatStyle": "grouped",
      "percentDisplayMode": "used"
    }
  },
  "lsp": true
}
